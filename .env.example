# Supabase project URL (public, embedded in bundle).
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon key — public JWT used for routing / rate-limiting. The user's
# session access token is sent as `Authorization: Bearer <jwt>` at runtime.
EXPO_PUBLIC_SUPABASE_KEY=

# Frankfurter exchange-rate endpoint (required).
EXPO_PUBLIC_FRANKFURTER_URL=https://api.frankfurter.app/latest?from=EUR&to=USD,CZK
